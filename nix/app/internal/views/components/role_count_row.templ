package components

import "fmt"

templ RoleCountRow(rowID string, roleKey string, label string, count int, badgeText string, badgeClass string, statusText string, statusClass string, incrementAction string, decrementAction string, locked bool, decrementDisabled bool) {
	<div
		id={ rowID }
		class="group border-b border-base-300 last:border-b-0"
		data-role-count-row={ roleKey }
	>
		if locked {
			<div data-stepper-locked={ roleKey } class="hidden"></div>
		} else {
			<div data-stepper={ roleKey } class="hidden"></div>
		}
		<div class="collapse collapse-arrow rounded-none duration-100">
			<input
				type="checkbox"
				name={ "accordion-" + roleKey }
				id={ "role-accordion-" + roleKey }
			/>
			<div class="collapse-title font-bold flex items-center gap-4">
				<div class="flex flex-col items-center gap-1 relative z-10">
					if locked {
						<button type="button" class="btn btn-primary relative z-20" disabled>+</button>
					} else {
						<button type="button" class="btn btn-primary relative z-20" data-on:click__stop={ incrementAction }>+</button>
					}
					<span class="text-lg font-bold">{ fmt.Sprintf("%d", count) }</span>
					if locked || decrementDisabled {
						<button type="button" class="btn btn-primary relative z-20" disabled>-</button>
					} else {
						<button type="button" class="btn btn-primary relative z-20" data-on:click__stop={ decrementAction }>-</button>
					}
				</div>
				<div class="flex items-center gap-2 flex-wrap min-w-0">
					<span class="font-bold">{ label }</span>
					if badgeText != "" {
						<span class={ "badge", badgeClass }>{ badgeText }</span>
					}
					if statusText != "" {
						<span class={ statusClass }>{ statusText }</span>
					}
				</div>
			</div>
			<div class="collapse-content text-sm text-base-content/80">
				{ children... }
			</div>
		</div>
	</div>
}
